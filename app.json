{
  "expo": {
    "name": "Dietas",
    "slug": "dietas",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/hospital_vivian_pellas.png",
    "scheme": "dietas",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0284c7",
        "foregroundImage": "./assets/images/hospital_vivian_pellas.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.hvp.dietas",
      "softwareKeyboardLayoutMode": "resize"
    },
    "androidStatusBar": {
      "barStyle": "dark-content",
      "backgroundColor": "#00000000",
      "translucent": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/hospital_vivian_pellas.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/hospital_vivian_pellas.png",
          "resizeMode": "contain",
          "backgroundColor": "#0284c7"
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
